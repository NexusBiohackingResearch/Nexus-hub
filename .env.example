# ============================================================
# NEXUS — Variables d'environnement
# Sur Railway : onglet "Variables" du service. En local : copie
# ce fichier en ".env" et remplis les valeurs.
# ============================================================

# --- Base de données (fourni AUTOMATIQUEMENT par le plugin Postgres de Railway) ---
# En local seulement, si tu n'utilises pas DATABASE_URL :
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=nexus
DATABASE_URL=

# --- Sécurité ---
# Génère une longue chaîne aléatoire (ex: openssl rand -hex 32)
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire
NODE_ENV=production

# --- Compte administrateur ---
# L'email ci-dessous devient automatiquement admin dès qu'un compte
# est créé avec cet email. Crée ton compte sur le site avec cet email.
ADMIN_EMAIL=yazid.amri.31@gmail.com

# --- Emails (Resend) ---
# Crée un compte sur resend.com, vérifie ton domaine, colle la clé ici.
# Sans clé, les emails s'affichent juste dans les logs (mode démo, aucun crash).
RESEND_API_KEY=
EMAIL_FROM=NEXUS <commandes@nexus-biohacking.com>

# --- Paiement crypto (affiché au client après commande) ---
CRYPTO_BTC=
CRYPTO_USDT=

# --- Divers ---
# URL publique du site (pour les liens dans les emails). Ex: https://nexus-biohacking.com
SITE_URL=
# Lien Telegram si tu veux le garder comme canal secondaire
TELEGRAM_URL=
