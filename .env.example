# ============================================================
# NEXUS — Variables d'environnement
# Sur Railway : onglet "Variables" du service. En local : copie
# ce fichier en ".env" et remplis les valeurs.
# ============================================================

# --- Base de données (fourni AUTOMATIQUEMENT par le plugin Postgres de Railway) ---
# En local seulement, si tu n'utilises pas DATABASE_URL :
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=nexus
DATABASE_URL=

# --- Sécurité ---
# Génère une longue chaîne aléatoire (ex: openssl rand -hex 32)
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire
NODE_ENV=production

# --- Compte administrateur ---
# L'email ci-dessous devient automatiquement admin dès qu'un compte
# est créé avec cet email. Crée ton compte sur le site avec cet email.
ADMIN_EMAIL=yazid.amri.31@gmail.com

# --- Emails (Resend) ---
# Crée un compte sur resend.com, vérifie ton domaine, colle la clé ici.
# Sans clé, les emails s'affichent juste dans les logs (mode démo, aucun crash).
RESEND_API_KEY=
EMAIL_FROM=NEXUS <commandes@nexus-biohacking.com>

# --- BTCPay Server (Greenfield API) ---
# Depuis ton BTCPay : Store Settings → Access Tokens (clé API avec droits
# btcpay.store.cancreateinvoice + btcpay.store.canviewinvoices)
BTCPAY_URL=https://ton-btcpay.exemple.com
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
# Webhook : dans BTCPay → Store → Webhooks → nouvelle URL
#   https://TON-SITE/api/btcpay/webhook   (événements: Invoice settled / processing)
# Colle ici le "secret" affiché à la création du webhook
BTCPAY_WEBHOOK_SECRET=

# --- Google Sheets (le MÊME compte de service que ton bot) ---
# Copie/colle le JSON complet du compte de service (une seule ligne) que tu as
# déjà mis dans le bot. La feuille doit être partagée avec l'email du compte de service.
GOOGLE_CREDENTIALS=
SPREADSHEET_ID=1pGnRnnQEmpnuwJiB6mkbFHaEmhh4wPFhCd4wtehAmKc
SHEET_NAME=Commande NEXUS

# --- Frais de port (repris du bot) ---
FRAIS_PORT=12
SEUIL_GRATUIT=150

# --- Divers ---
# URL publique du site (pour les liens emails + retour BTCPay). Ex: https://nexus-biohacking.com
SITE_URL=
# Lien Telegram si tu veux le garder comme canal secondaire
TELEGRAM_URL=
